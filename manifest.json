{
  "manifest_version": 3,
  "name": "NCD Automation System",
  "version": "1.0",
  "description": "Google Sheet based NCD automation",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["gsheet.js", "content.js"]
    }
  ]
}
