{
  "manifest_version": 3,
  "name": "NCD Extension",
  "version": "1.0",
  "description": "NCD automation extension",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
